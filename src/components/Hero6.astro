---
const { t, isJa } = Astro.props;
---

<section class="container mx-auto pt-32 md:pt-60 px-6 relative">
    <!-- Dynamic Metadata Header -->
    <div
        class="flex flex-wrap items-center gap-x-8 gap-y-4 mb-12 font-mono text-[10px] md:text-xs tracking-[0.2em] uppercase text-emerald-500/60 animate-fadeIn_2000"
    >
        <div class="flex items-center gap-2">
            <span
                class="h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_#10b981]"
            ></span>
            <span>Status: Available</span>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-white/20">//</span>
            <span>Loc: Vienna, AT [48.2082° N, 16.3738° E]</span>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-white/20">//</span>
            <span>Time: <span id="vienna-time">00:00:00</span> CET</span>
        </div>
    </div>

    <div class="relative">
        <h1
            class={`font-andesNeueMedium leading-[0.8] animate-fadeIn_2000 ${isJa ? "text-6xl md:text-9xl" : "text-8xl md:text-[14rem]"} text-white`}
        >
            {t.name}
        </h1>
        <h1
            class={`font-andesNeueMedium leading-[0.8] animate-fadeIn_2200 ${isJa ? "text-6xl md:text-9xl" : "text-8xl md:text-[14rem]"} text-transparent bg-linear-to-b from-emerald-500 via-emerald-800 to-transparent bg-clip-text -mt-2 md:-mt-6`}
        >
            {t.lastname}
        </h1>

        <!-- Vertical Branding -->
        <div
            class="absolute -right-4 top-0 h-full hidden lg:flex flex-col justify-between py-4 translate-x-full"
        >
            <span
                class="font-mono text-[10px] rotate-90 origin-left whitespace-nowrap text-white/20 uppercase tracking-[0.5em]"
                >Digital Media Specialist</span
            >
            <span
                class="font-mono text-[10px] rotate-90 origin-left whitespace-nowrap text-white/20 uppercase tracking-[0.5em]"
                >IT Infrastructure</span
            >
        </div>
    </div>
</section>

<script>
    function updateTime() {
        const timeSpan = document.getElementById("vienna-time");
        if (!timeSpan) return;
        const now = new Date().toLocaleTimeString("en-GB", {
            timeZone: "Europe/Vienna",
            hour12: false,
        });
        timeSpan.textContent = now;
    }
    setInterval(updateTime, 1000);
    updateTime();
</script>

<section class="container mx-auto pt-32 md:pt-60 px-6">
    <div class="grid grid-cols-12 border-t border-white/10 pt-8 relative">
        <!-- Grid Marks -->
        <span
            class="absolute -top-[5px] left-0 text-emerald-500 font-mono text-xs"
            >+</span
        >
        <span
            class="absolute -top-[5px] right-0 text-emerald-500 font-mono text-xs"
            >+</span
        >

        <div class="col-span-12 lg:col-span-8">
            <h1 class="font-andesNeueMedium text-white animate-fadeIn_2000">
                <span
                    class={`block leading-none ${isJa ? "text-7xl" : "text-8xl md:text-[12rem]"}`}
                    >{t.name}</span
                >
                <span
                    class={`block leading-none opacity-20 ${isJa ? "text-7xl" : "text-8xl md:text-[12rem]"}`}
                    >{t.lastname}</span
                >
            </h1>
        </div>

        <div
            class="col-span-12 lg:col-span-4 flex flex-col justify-end gap-12 mt-12 lg:mt-0 lg:pl-12 border-l border-white/10 animate-fadeIn_2200"
        >
            <div class="space-y-2">
                <p
                    class="font-mono text-[10px] uppercase text-emerald-500 tracking-widest"
                >
                    Base Operations
                </p>
                <p class="text-xl text-white font-andesNeueLight leading-tight">
                    Vienna, Austria<br />
                    <span class="text-gray-500">Central European Time</span>
                </p>
            </div>

            <div class="space-y-2">
                <p
                    class="font-mono text-[10px] uppercase text-emerald-500 tracking-widest"
                >
                    Expertise
                </p>
                <p class="text-gray-400 font-andesNeueLight italic">
                    Blending aesthetic digital media with high-performance IT
                    systems.
                </p>
            </div>
        </div>
    </div>
</section>

<section
    class="container mx-auto pt-32 md:pt-60 px-6 flex flex-col items-center text-center overflow-hidden"
>
    <div class="relative inline-block">
        <!-- Huge Live Time Background -->
        <div
            class="absolute inset-0 flex items-center justify-center pointer-events-none -z-10"
        >
            <span
                id="big-time"
                class="text-[25vw] font-mono font-bold text-white/[0.02] leading-none whitespace-nowrap"
            >
                00:00
            </span>
        </div>

        <div class="space-y-4">
            <span
                class="inline-block px-4 py-1 rounded-full border border-emerald-500/30 text-emerald-500 font-mono text-[10px] uppercase tracking-[0.4em] animate-fadeIn_2000"
            >
                Digital Media & IT \ VIE
            </span>

            <h1
                class={`font-andesNeueMedium text-white animate-fadeIn_2000 tracking-tight leading-[0.8]
        ${isJa ? "text-7xl md:text-9xl" : "text-8xl md:text-[15rem]"}`}
            >
                {t.name}<br />{t.lastname}
            </h1>
        </div>
    </div>

    <div class="mt-16 max-w-lg animate-fadeIn_2200">
        <p
            class="text-gray-400 font-andesNeueLight text-lg md:text-xl leading-relaxed"
        >
            Designing digital systems from the <span
                class="text-emerald-500 font-mono">heart of Europe</span
            >. Bridging the gap between content and code.
        </p>
    </div>
</section>

<script>
    function updateBigTime() {
        const timeSpan = document.getElementById("big-time");
        if (!timeSpan) return;
        const now = new Date().toLocaleTimeString("en-GB", {
            timeZone: "Europe/Vienna",
            hour: "2-digit",
            minute: "2-digit",
        });
        timeSpan.textContent = now;
    }
    setInterval(updateBigTime, 1000);
    updateBigTime();
</script>
