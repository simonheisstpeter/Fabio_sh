---
/**
 * Progressive-enhancement contact form.
 *
 * Without JS  → standard HTML form POST → redirect to /?sent=1 or /?error=1
 * With JS     → fetch() intercepts submit → inline feedback, no page reload
 *
 * Anti-spam:
 *  1. Honeypot hidden field (bots fill it, humans ignore it)
 *  2. Timing check: _t field filled by JS with load timestamp
 *     (server rejects submissions < 3 s after page load)
 *  3. Rate limiting on the server side (IP hash, SQLite)
 */

import type { Translations } from '../i18n/index';

interface Props {
  t: Translations;
  /** Show success/error status based on URL param (no-JS flow) */
  sent?: boolean;
  error?: boolean;
  /** The form action URL — defaults to /api/contact */
  action?: string;
}

const {
  t,
  sent = false,
  error = false,
  action = '/api/contact',
} = Astro.props;
---

{sent && (
  <div role="status" aria-live="polite" class="mb-6 rounded-md border border-emerald-500 bg-emerald-950/40 px-4 py-3 text-emerald-400">
    {t.contactSuccess}
  </div>
)}

{error && (
  <div role="alert" class="mb-6 rounded-md border border-red-500 bg-red-950/40 px-4 py-3 text-red-400">
    {t.contactError}
  </div>
)}

<form
  id="contact-form"
  action={action}
  method="POST"
  novalidate
  class="w-full md:w-4/5 mx-auto max-w-xl my-12 text-white"
>
  <!--
    Honeypot: positioned off-screen visually but NOT display:none or visibility:hidden
    because some bots detect those. Humans ignore it; bots fill it.
  -->
  <div
    aria-hidden="true"
    style="position:absolute;left:-9999px;top:-9999px;opacity:0;height:0;overflow:hidden;"
    tabindex="-1"
  >
    <label for="website-hp">Website</label>
    <input
      type="text"
      id="website-hp"
      name="website"
      autocomplete="off"
      tabindex="-1"
    />
  </div>

  <!-- Timestamp filled by JS (server rejects if missing or too fresh) -->
  <input type="hidden" name="_t" id="form-ts" value="" />

  <!-- Name -->
  <div class="mt-4 mb-6 flex flex-col gap-2">
    <label for="contact-name" class="font-andesNeueMedium">{t.contactName}</label>
    <div class="bg-linear-to-t from-white/20 ring-1 ring-white/10 rounded-sm p-1">
      <input
        type="text"
        id="contact-name"
        name="name"
        autocomplete="name"
        required
        minlength="2"
        maxlength="100"
        placeholder={`${t.contactName}…`}
        class="bg-darkDotsGray w-full p-2 px-3 block rounded-sm border border-white/10 focus:border-gray-400 outline-2 outline-white"
      />
    </div>
  </div>

  <!-- Email -->
  <div class="mt-4 mb-6 flex flex-col gap-2">
    <label for="contact-email" class="font-andesNeueMedium">{t.contactEMail}</label>
    <div class="bg-linear-to-t from-white/20 ring-1 ring-white/10 rounded-sm p-1">
      <input
        type="email"
        id="contact-email"
        name="email"
        autocomplete="email"
        required
        maxlength="254"
        placeholder={`${t.contactEMail}…`}
        class="bg-darkDotsGray w-full p-2 px-3 block rounded-sm border border-white/10 focus:border-gray-400 outline-2 outline-white"
      />
    </div>
  </div>

  <!-- Message -->
  <div class="mt-4 mb-6 flex flex-col gap-2">
    <label for="contact-message" class="font-andesNeueMedium">{t.contactMessage}</label>
    <div class="bg-linear-to-t from-white/20 ring-1 ring-white/10 rounded-sm p-1">
      <textarea
        id="contact-message"
        name="message"
        required
        minlength="10"
        maxlength="2000"
        rows="5"
        placeholder={`${t.contactMessage}…`}
        class="bg-darkDotsGray w-full p-2 px-3 block rounded-sm border border-white/10 focus:border-gray-400 outline-2 outline-white resize-y"
      ></textarea>
    </div>
  </div>

  <!-- Inline feedback (JS only) -->
  <div id="form-feedback" role="status" aria-live="polite" class="mb-4 hidden"></div>

  <button
    type="submit"
    id="contact-submit"
    class="w-44 mt-4 py-2 bg-emerald-600 border border-emerald-700 rounded-sm transition duration-300 ease-in-out ring-emerald-500 text-white outline-emerald-400 hover:bg-darkDotsGray hover:text-emerald-500 focus:outline-solid outline-2 outline-offset-4 text-lg font-andesNeueMedium disabled:opacity-60 disabled:cursor-not-allowed"
  >
    {t.contactButton}!
  </button>
</form>

<script define:vars={{ successMsg: t.contactSuccess, errorMsg: t.contactError }}>
  const form = document.getElementById('contact-form');
  const tsInput = document.getElementById('form-ts');
  const submitBtn = document.getElementById('contact-submit');
  const feedback = document.getElementById('form-feedback');

  // Fill timestamp on load
  if (tsInput) tsInput.value = String(Date.now());

  if (form && submitBtn && feedback) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = '…';
      feedback.className = 'mb-4 hidden';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });

        const json = await res.json().catch(() => ({}));

        if (res.ok && json.ok) {
          // Success: replace form with message
          form.innerHTML = `<p class="text-emerald-400 text-lg font-andesNeueMedium py-8">${successMsg}</p>`;
        } else {
          feedback.textContent = json.message ?? errorMsg;
          feedback.className = 'mb-4 rounded-md border border-red-500 bg-red-950/40 px-4 py-3 text-red-400';
          submitBtn.disabled = false;
          submitBtn.textContent = submitBtn.dataset.label ?? 'Send!';
        }
      } catch {
        feedback.textContent = errorMsg;
        feedback.className = 'mb-4 rounded-md border border-red-500 bg-red-950/40 px-4 py-3 text-red-400';
        submitBtn.disabled = false;
        submitBtn.textContent = submitBtn.dataset.label ?? 'Send!';
      }
    });

    // Store original label for reset
    submitBtn.dataset.label = submitBtn.textContent ?? '';
  }
</script>
