---
import type { Translations } from "../i18n/index";

interface Props {
    t: Translations;
    sent?: boolean;
    error?: boolean;
    action?: string;
}

const {
    t,
    sent = false,
    error = false,
    action = "/api/contact",
}: Props = Astro.props;
---

<div class="relative w-full max-w-2xl mx-auto my-12 animate-fadeIn_2200">
    <!-- Background Glow Decoration -->
    <div
        class="absolute -left-16 -top-16 h-64 w-64 rounded-full bg-emerald-500/5 blur-[100px] pointer-events-none"
    >
    </div>
    <div
        class="absolute -right-16 -bottom-16 h-64 w-64 rounded-full bg-emerald-500/5 blur-[100px] pointer-events-none"
    >
    </div>

    <div
        class="relative overflow-hidden rounded-3xl border border-white/10 p-8 md:p-12 backdrop-blur-xs"
    >
        {
            sent && (
                <div
                    role="status"
                    aria-live="polite"
                    class="mb-8 flex items-center gap-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-6 py-4 text-emerald-400"
                >
                    <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse" />
                    {t.contactSuccess}
                </div>
            )
        }

        {
            error && (
                <div
                    role="alert"
                    class="mb-8 flex items-center gap-3 rounded-xl border border-red-500/30 bg-red-500/10 px-6 py-4 text-red-400"
                >
                    <span class="h-2 w-2 rounded-full bg-red-500 animate-pulse" />
                    {t.contactError}
                </div>
            )
        }

        <form
            id="contact-form"
            action={action}
            method="POST"
            novalidate
            class="space-y-8 text-white"
        >
            <!-- Honeypot -->
            <div aria-hidden="true" class="hidden">
                <input type="text" name="website" tabindex="-1" />
            </div>
            <input type="hidden" name="_t" id="form-ts" value="" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Name -->
                <div class="group flex flex-col gap-3">
                    <label
                        for="contact-name"
                        class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-emerald-500/70"
                    >
                        <span>01 //</span>
                        {t.contactName}
                    </label>
                    <input
                        type="text"
                        id="contact-name"
                        name="name"
                        required
                        placeholder="John Doe"
                        class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 outline-none transition-all duration-300 focus:border-emerald-500/50 focus:bg-white/8 focus:ring-4 focus:ring-emerald-500/5 placeholder:text-white/20"
                    />
                </div>

                <!-- Email -->
                <div class="group flex flex-col gap-3">
                    <label
                        for="contact-email"
                        class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-emerald-500/70"
                    >
                        <span>02 //</span>
                        {t.contactEMail}
                    </label>
                    <input
                        type="email"
                        id="contact-email"
                        name="email"
                        required
                        placeholder="hello@example.com"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 outline-none transition-all duration-300 focus:border-emerald-500/50 focus:bg-white/[0.08] focus:ring-4 focus:ring-emerald-500/5 placeholder:text-white/20"
                    />
                </div>
            </div>

            <!-- Message -->
            <div class="group flex flex-col gap-3">
                <label
                    for="contact-message"
                    class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-emerald-500/70"
                >
                    <span>03 //</span>
                    {t.contactMessage}
                </label>
                <textarea
                    id="contact-message"
                    name="message"
                    required
                    rows="5"
                    placeholder={`${t.contactMessage}...`}
                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 outline-none transition-all duration-300 focus:border-emerald-500/50 focus:bg-white/[0.08] focus:ring-4 focus:ring-emerald-500/5 placeholder:text-white/20 resize-none"
                ></textarea>
            </div>

            <div
                id="form-feedback"
                role="status"
                aria-live="polite"
                class="hidden"
            >
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
                <button
                    type="submit"
                    id="contact-submit"
                    class="group relative w-full md:w-auto px-10 py-4 bg-emerald-500 text-darkDotsGray font-andesNeueMedium rounded-xl overflow-hidden transition-all duration-300 hover:scale-[1.02] active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
                >
                    <span
                        class="relative z-10 flex items-center justify-center gap-2"
                    >
                        {t.contactButton}
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </span>
                    <div
                        class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shimmer"
                    >
                    </div>
                </button>
            </div>
        </form>
    </div>
</div>

<script define:vars={{ successMsg: t.contactSuccess, errorMsg: t.contactError }}
>
    // Keep your existing JS logic here, just ensure IDs match
    const form = document.getElementById("contact-form");
    const tsInput = document.getElementById("form-ts");
    const submitBtn = document.getElementById("contact-submit");
    const feedback = document.getElementById("form-feedback");

    if (tsInput) tsInput.value = String(Date.now());

    if (form && submitBtn && feedback) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = "Processing...";

            try {
                const res = await fetch(form.action, {
                    method: "POST",
                    body: new FormData(form),
                    headers: { Accept: "application/json" },
                });

                const json = await res.json().catch(() => ({}));

                if (res.ok && json.ok) {
                    form.innerHTML = `<div class="flex flex-col items-center justify-center py-12 text-center">
                        <div class="h-16 w-16 bg-emerald-500/20 text-emerald-500 rounded-full flex items-center justify-center mb-6">
                             <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-emerald-400 text-2xl font-andesNeueMedium">${successMsg}</p>
                    </div>`;
                } else {
                    throw new Error();
                }
            } catch {
                feedback.textContent = errorMsg;
                feedback.className =
                    "mt-6 rounded-xl border border-red-500/30 bg-red-500/10 px-6 py-4 text-red-400 block";
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });
    }
</script>

<style>
    @keyframes shimmer {
        100% {
            transform: translateX(100%);
        }
    }
    .animate-shimmer {
        animation: shimmer 1.5s infinite;
    }
</style>
