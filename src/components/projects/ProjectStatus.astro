---
import { getTranslations } from '../../i18n/index';

interface Props {
  title: string;
  online: boolean;
  finished: boolean;
}
const { title, online, finished } = Astro.props;

const locale = Astro.currentLocale ?? 'de';
const t = getTranslations(locale);

const dotColor = online ? 'bg-emerald-400' : finished ? 'bg-red-400' : 'bg-yellow-400';
const statusLabel = online ? t.statusOnline : finished ? t.statusOffline : t.statusStandby;
---

<div class="mb-2 flex items-center gap-2">
  <span class="relative group shrink-0 flex items-center justify-center cursor-default">
    <span
      class={`h-2 w-2 rounded-full ${dotColor}`}
      aria-label={statusLabel}
    ></span>
    <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-0.5 text-xs rounded bg-neutral-800 text-white opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
      {statusLabel}
    </span>
  </span>
  <h3 class="font-andesNeueMedium text-white leading-snug">{title}</h3>
</div>
