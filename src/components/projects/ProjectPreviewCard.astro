---
interface Props {
    title: string;
    index: number;
}

const { title, index }: Props = Astro.props;
// Format index to 01, 02, etc.
const displayIndex = String(index + 1).padStart(2, "0");
---

<li class="list-none">
    <article
        class="group relative overflow-hidden rounded-2xl bg-white/5 border border-white/10 p-8 transition-all duration-500 hover:-translate-y-2 hover:bg-white/8 hover:border-emerald-500/30 animate-fadeIn_2200"
        style={`animation-delay: ${index * 150}ms`}
    >
        <!-- Decorative Background Glow -->
        <div
            class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-emerald-500/5 blur-3xl group-hover:bg-emerald-500/15 transition-all duration-500"
        >
        </div>

        <div class="relative z-10 flex flex-col h-full justify-between">
            <div>
                <span
                    class="text-emerald-500 font-mono text-xs mb-4 block opacity-70 tracking-tighter"
                >
                    {displayIndex} // PREVIEW
                </span>
                <h3
                    class="text-xl md:text-2xl font-andesNeueMedium text-gray-100 group-hover:text-white transition-colors leading-tight"
                >
                    {title}
                </h3>
            </div>

            <div
                class="mt-12 flex items-center text-[10px] font-andesNeueMedium text-emerald-500/60 uppercase tracking-[0.2em]"
            >
                <span class="w-6 h-px bg-emerald-500/30 mr-3"></span>
                Active Status
            </div>
        </div>
    </article>
</li>
