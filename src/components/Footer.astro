---
import type { Translations } from "../i18n/index";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
    locale: string;
    t: Translations;
}

const { locale, t }: Props = Astro.props;
const email = "fabio@fabio.sh";

const footerLinks = [
    {
        title: "Mediakit",
        href: getRelativeLocaleUrl(locale, "/mediakit"),
    },
    {
        title: "llms.txt",
        href: "/llms.txt",
    },
    {
        title: "CV",
        href: getRelativeLocaleUrl(locale, "/cv"),
    },
];
---

<footer
    class="container mx-auto select-none font-andesNeueLight my-20 flex justify-between px-4 md:px-12"
>
    <div>
        <p class="text-sm text-white/60" data-obfuscation="0">
            {t.contactEMail}
        </p>
        <a
            href={`mailto:${email}`}
            data-obfuscation="0"
            class="transition-colors hover:text-emerald-400 text-white duration-200"
        >
            {email}
        </a>
    </div>

    <ul class="flex flex-col gap-2 text-sm text-right">
        {
            footerLinks.map(({ title, href }) => (
                <li>
                    <a
                        href={href}
                        class="transition-colors duration-200 text-white/60 hover:text-emerald-400"
                    >
                        {title}
                    </a>
                </li>
            ))
        }
    </ul>
</footer>
