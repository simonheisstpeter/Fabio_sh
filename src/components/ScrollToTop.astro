---
interface Props {
    label: string;
}
const { label }: Props = Astro.props;
---

<a
    href="#top"
    id="scroll-top-btn"
    aria-label={label}
    class="fixed bottom-6 right-6 z-50 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-600 text-white shadow-lg opacity-0 pointer-events-none transition-opacity duration-300"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="h-5 w-5"
        aria-hidden="true"
    >
        <path
            fill-rule="evenodd"
            d="M10 17a.75.75 0 01-.75-.75V5.612L5.29 9.77a.75.75 0 01-1.08-1.04l5.25-5.5a.75.75 0 011.08 0l5.25 5.5a.75.75 0 11-1.08 1.04l-3.96-4.158V16.25A.75.75 0 0110 17z"
            clip-rule="evenodd"></path>
    </svg>
</a>

<script>
    const btn = document.getElementById("scroll-top-btn");
    if (btn) {
        const toggle = () => {
            const visible = window.scrollY > 300;
            btn.style.opacity = visible ? "1" : "0";
            btn.style.pointerEvents = visible ? "auto" : "none";
        };
        window.addEventListener("scroll", toggle, { passive: true });
        toggle();

        btn.addEventListener("click", (e) => {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    }
</script>
