---
import { ClientRouter } from "astro:transitions";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getTranslations, LOCALES, LOCALE_LABELS } from "../i18n/index";
import Footer from "./Footer.astro";
import Loader from "./Loader.astro";
import ScrollToTop from "./ScrollToTop.astro";
import "../styles/globals.css";

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
}

const {
    title = "fabio.sh",
    description = "Fabio Gschweidl – digital media & IT",
    ogImage = "/meta_pic.png",
} = Astro.props;

const locale = Astro.currentLocale ?? "de";
const t = getTranslations(locale);

// Build language switcher URLs
const currentPath = Astro.url.pathname;
const localePrefixRe = new RegExp(`^\\/(${LOCALES.join("|")})(\\/$|$|\\/)`);

function getPathForLocale(targetLocale: string) {
    return (
        getRelativeLocaleUrl(targetLocale, "/").replace(/\/$/, "") +
        (currentPath === "/" ? "/" : currentPath.replace(localePrefixRe, "/"))
    );
}

const isHome =
    currentPath === "/" ||
    LOCALES.some((l) => currentPath === `/${l}` || currentPath === `/${l}/`);

const siteUrl = "https://fabio.sh";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang={locale} class="dotsDark scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="dark" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />

        <!-- Favicons -->
        <link rel="icon" href="/carp_streamer.ico" />
        <link
            rel="apple-touch-icon"
            href="/apple-touch-icon.png"
            sizes="180x180"
        />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={`${siteUrl}${ogImage}`} />
        <meta property="og:site_name" content="fabio.sh" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

        <!-- Font preloads -->
        <link
            rel="preload"
            href="/fonts/AndesNeue-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href="/fonts/AndesNeue-Light.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />

        <!-- Hreflang for SEO -->
        {
            LOCALES.map((l) => (
                <link
                    rel="alternate"
                    hreflang={l}
                    href={`${siteUrl}${getRelativeLocaleUrl(l, "/")}`}
                />
            ))
        }

        <ClientRouter />
    </head>

    <body
        class="cursor-fabiosh min-h-screen bg-darkDotsGray text-white font-andesNeueLight relative"
    >
        <a href="main" class="skip.link">to Main</a>
        <a id="top" class="sr-only" tabindex="-1" aria-hidden="true">top</a>

        <!-- Beta ribbon -->
        <div class="beta-ribbon" aria-hidden="true">
            <span>BETA Version</span>
        </div>

        <!-- Mobile nav -->
        <nav
            class="fixed top-0 z-20 w-full bg-darkDotsGray/95 backdrop-blur-sm md:hidden"
            aria-label={t.menuHome}
        >
            <details class="group">
                <summary
                    class="flex items-center justify-end px-6 py-4 list-none cursor-pointer select-none"
                    aria-label="Toggle Menu"
                >
                    <!-- Hamburger icon (visible when closed) -->
                    <svg
                        class="h-7 w-7 group-open:hidden"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <!-- Close icon (visible when open) -->
                    <svg
                        class="h-7 w-7 hidden group-open:block"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                            clip-rule="evenodd"></path>
                    </svg>
                </summary>

                <div class="dotsDark h-screen pt-24 text-center">
                    <nav
                        class="grid grid-cols-1 text-2xl gap-6 font-andesNeueMedium"
                    >
                        <a
                            href={getRelativeLocaleUrl(locale, "/")}
                            class="py-2 hover:text-emerald-400 transition duration-200"
                            >{t.menuHome}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(locale, "/projects")}
                            class="py-2 hover:text-emerald-400 transition duration-200"
                            >{t.menuProjects}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(locale, "/about")}
                            class="py-2 hover:text-emerald-400 transition duration-200"
                            >{t.menuAbout}</a
                        >
                        <a
                            href={getRelativeLocaleUrl(locale, "/contact")}
                            class="py-2 hover:text-emerald-400 transition duration-200"
                            >{t.menuContact}</a
                        >

                        <div class="mt-4">
                            <select
                                id="lang-select-mobile"
                                aria-label={t.languageSelect}
                                class="bg-transparent text-white text-lg tracking-wide border border-white/20 rounded-md px-3 py-1"
                            >
                                {
                                    LOCALES.map((l) => (
                                        <option
                                            value={getPathForLocale(l)}
                                            selected={l === locale}
                                        >
                                            {LOCALE_LABELS[l]}
                                        </option>
                                    ))
                                }
                            </select>
                        </div>
                    </nav>
                </div>
            </details>
        </nav>

        <!-- Desktop nav -->
        <header class="hidden md:block">
            <nav
                class="flex items-start justify-between pr-10 pt-10"
                aria-label="Main navigation"
            >
                <a
                    href={getRelativeLocaleUrl(locale, "/")}
                    aria-current={isHome ? "page" : undefined}
                    aria-label={t.menuHome}
                    class="ml-6"
                >
                    <Loader />
                </a>

                <div
                    class="flex items-center gap-6 font-andesNeueLight text-sm tracking-wide"
                >
                    <a
                        href={getRelativeLocaleUrl(locale, "/projects")}
                        aria-current={Astro.url.pathname.includes("/projects")
                            ? "page"
                            : undefined}
                        class="transition-colors duration-200 hover:text-emerald-400 aria-[current=page]:text-emerald-400"
                    >
                        {t.menuProjects}
                    </a>
                    <a
                        href={getRelativeLocaleUrl(locale, "/about")}
                        aria-current={Astro.url.pathname.includes("/about")
                            ? "page"
                            : undefined}
                        class="transition-colors duration-200 hover:text-emerald-400 aria-[current=page]:text-emerald-400"
                    >
                        {t.menuAbout}
                    </a>
                    <a
                        href={getRelativeLocaleUrl(locale, "/contact")}
                        aria-current={Astro.url.pathname.includes("/contact")
                            ? "page"
                            : undefined}
                        class="transition-colors duration-200 hover:text-emerald-400 aria-[current=page]:text-emerald-400"
                    >
                        {t.menuContact}
                    </a>

                    <select
                        id="lang-select"
                        aria-label={t.languageSelect}
                        class="bg-transparent text-white tracking-wide border-none cursor-pointer hover:text-emerald-400 transition duration-200"
                    >
                        {
                            LOCALES.map((l) => (
                                <option
                                    value={getPathForLocale(l)}
                                    selected={l === locale}
                                >
                                    {LOCALE_LABELS[l]}
                                </option>
                            ))
                        }
                    </select>
                </div>
            </nav>
        </header>

        <main id="main-content" class="font-andesNeueLight">
            <slot />
        </main>

        <ScrollToTop label={t.scrollTop} />
        <Footer locale={locale} t={t} />

        <!-- Language switcher script (progressive: enhances <select> navigation) -->
        <script>
            function initLangSelect(id: string) {
                const sel = document.getElementById(
                    id,
                ) as HTMLSelectElement | null;
                if (!sel || sel.dataset.lsInit) return;
                sel.dataset.lsInit = "1";
                sel.addEventListener("change", () => {
                    if (sel.value) window.location.href = sel.value;
                });
            }
            // astro:page-load fires on both initial load and after every View Transition
            document.addEventListener("astro:page-load", () => {
                initLangSelect("lang-select");
                initLangSelect("lang-select-mobile");
            });
        </script>
    </body>
</html>

<style>
    .beta-ribbon {
        position: fixed;
        display: flex;
        justify-content: center;
        align-items: center;
        bottom: 0;
        left: 0;
        width: 140px;
        height: 30px;
        overflow: hidden;
        z-index: 1003;
        pointer-events: none;
        border-radius: 0 8px 0 8px;
        border: 1px solid #34d399;
        border-left: 0;
        border-bottom: 0;
        background: rgba(144, 144, 144, 0.2);
        box-shadow: 0 0 10px rgba(177, 177, 177, 0.5);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);

        span {
            text-align: center;
            font-family: monospace;
            font-size: 0.62rem;
            font-weight: 900;
            letter-spacing: 0.12em;
            color: #34d399;
            text-shadow:
                0 0 6px #34d399,
                0 0 12px #34d399;
            text-transform: uppercase;
            line-height: 1;
        }
    }

    .skip.link {
        position: absolute;
        top: -40px;
        left: -100px;
        background: #34d399;
        color: white;
        padding: 8px 16px;
        text-decoration: none;
        z-index: 1004;
    }

    .skip.link:focus {
        top: 0;
    }
</style>
