---
import '../styles/globals.css';

interface Props {
  title: string;
}
const { title } = Astro.props;

const path = Astro.url.pathname;
const navLink = 'text-gray-400 no-underline text-sm py-1 border-b-2 border-transparent transition-colors hover:text-emerald-400 hover:border-emerald-400 aria-[current=page]:text-emerald-400 aria-[current=page]:border-emerald-400';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} – Admin · fabio.sh</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body class="bg-[#0a0a0a] text-gray-200 min-h-screen flex flex-col font-sans">
    <header class="bg-[#111] border-b border-[#222] px-6 flex items-center gap-8 h-14 shrink-0">
      <a href="/admin" class="text-emerald-400 font-semibold text-base no-underline">fabio.sh admin</a>
      <nav class="flex gap-6 flex-1">
        <a
          href="/admin"
          aria-current={path === '/admin' ? 'page' : undefined}
          class={navLink}
        >Dashboard</a>
        <a
          href="/admin/projects"
          aria-current={path.startsWith('/admin/projects') ? 'page' : undefined}
          class={navLink}
        >Projects</a>
        <a
          href="/admin/submissions"
          aria-current={path.startsWith('/admin/submissions') ? 'page' : undefined}
          class={navLink}
        >Submissions</a>
      </nav>
      <form action="/api/auth/logout" method="POST" class="ml-auto">
        <button
          type="submit"
          class="bg-transparent border border-gray-700 text-gray-400 px-3 py-1 rounded text-xs cursor-pointer transition-colors hover:border-red-500 hover:text-red-500"
        >Logout</button>
      </form>
    </header>
    <main class="flex-1 p-8 max-w-275 w-full mx-auto">
      <slot />
    </main>
  </body>
</html>
