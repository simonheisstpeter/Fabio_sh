---
import Layout from '../components/Layout.astro';
import Loader from '../components/Loader.astro';
import { getTranslations } from '../i18n/index';

const locale = Astro.currentLocale ?? 'de';
const t = getTranslations(locale);

const colors = [
  { name: 'White',       hex: '#ffffff', class: 'bg-white border border-white/30' },
  { name: 'Dark Gray',   hex: '#030303', class: 'bg-darkDotsGray border border-white/30' },
  { name: 'Emerald 400', hex: '#34d399', class: 'bg-emerald-400' },
  { name: 'Emerald 500', hex: '#10b981', class: 'bg-emerald-500' },
];
---

<Layout
  title={`${t.mediakitTitle} – fabio.sh`}
  description="Brand guidelines and media kit for fabio.sh"
>
  <div class="container mx-auto pt-24 md:pt-32 font-andesNeueLight px-6 md:px-12 pb-12">
    <h1 class="text-3xl md:text-5xl font-andesNeueMedium mb-12 text-white animate-fadeIn_2000">
      {t.mediakitTitle}
    </h1>

    <!-- Fonts -->
    <section aria-labelledby="section-fonts" class="mb-16">
      <h2
        id="section-fonts"
        class="border-b-2 border-emerald-400 pb-1 text-white hover:text-emerald-400 duration-200 inline-block mb-10"
      >
        {t.mediakitFonts}
      </h2>
      <div class="md:w-2/3 text-white space-y-6">
        <div>
          <p class="font-andesNeueMedium text-3xl mb-3">Andes Neue Medium</p>
          <button
            class="copy-btn font-mono text-xs text-emerald-500 bg-white/5 hover:bg-white/10 border border-white/10 rounded px-3 py-1.5 cursor-pointer transition-colors text-left"
            data-copy="font-family: 'AndesNeueMedium', sans-serif; font-weight: 500;"
          >font-family: 'AndesNeueMedium', sans-serif; font-weight: 500;</button>
        </div>
        <div>
          <p class="font-andesNeueLight text-3xl mb-3">Andes Neue Light</p>
          <button
            class="copy-btn font-mono text-xs text-emerald-500 bg-white/5 hover:bg-white/10 border border-white/10 rounded px-3 py-1.5 cursor-pointer transition-colors text-left"
            data-copy="font-family: 'AndesNeueLight', sans-serif; font-weight: 300;"
          >font-family: 'AndesNeueLight', sans-serif; font-weight: 300;</button>
        </div>
      </div>
    </section>

    <!-- Colors -->
    <section aria-labelledby="section-colors" class="mb-16">
      <h2
        id="section-colors"
        class="border-b-2 border-emerald-400 pb-1 text-white hover:text-emerald-400 duration-200 inline-block mb-10"
      >
        {t.mediakitColors}
      </h2>
      <div class="md:w-2/3 grid grid-cols-2 md:grid-cols-4 gap-8 text-white">
        {colors.map(({ name, hex, class: cls }) => (
          <button
            class="copy-btn text-center bg-transparent border-0 cursor-pointer group p-0"
            data-copy={hex}
          >
            <div class={`h-20 w-20 mx-auto ${cls} rounded-full mb-4 transition-transform duration-200 group-hover:scale-105`}></div>
            <span class="block text-sm">{name}</span>
            <span class="block text-xs text-emerald-500 font-mono mt-1">{hex}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Cursor -->
    <section aria-labelledby="section-cursor" class="mb-16">
      <h2
        id="section-cursor"
        class="border-b-2 border-emerald-400 pb-1 text-white hover:text-emerald-400 duration-200 inline-block mb-10"
      >
        {t.mediakitCursor}
      </h2>
      <div class="md:w-2/3">
        <img src="/f.png" height="30" width="30" alt="Custom F cursor – fabio.sh" loading="lazy" />
      </div>
    </section>

    <!-- Loader -->
    <section aria-labelledby="section-loader" class="mb-16">
      <h2
        id="section-loader"
        class="border-b-2 border-emerald-400 pb-1 text-white hover:text-emerald-400 duration-200 inline-block mb-10"
      >
        {t.mediakitLoader}
      </h2>
      <div class="md:w-2/3 flex justify-center">
        <Loader big />
      </div>
    </section>
  </div>
</Layout>

<script>
  function showTooltip(anchor: HTMLElement) {
    const existing = anchor.querySelector<HTMLElement>('.copy-tooltip');
    if (existing) return;
    const tip = document.createElement('span');
    tip.className = 'copy-tooltip';
    tip.textContent = 'Copied!';
    tip.style.cssText =
      'position:absolute;left:50%;transform:translateX(-50%);bottom:calc(100% + 6px);' +
      'background:#18181b;color:#34d399;font-size:0.7rem;white-space:nowrap;' +
      'padding:2px 8px;border-radius:4px;pointer-events:none;z-index:50;';
    anchor.style.position = 'relative';
    anchor.appendChild(tip);
    setTimeout(() => tip.remove(), 1500);
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      if (btn.dataset.copyInit) return;
      btn.dataset.copyInit = '1';
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy ?? btn.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          showTooltip(btn);
        } catch {
          // clipboard API unavailable (non-HTTPS or denied)
        }
      });
    });
  });
</script>
