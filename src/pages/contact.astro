---
import Layout from '../components/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { getTranslations } from '../i18n/index';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale ?? 'de';
const t = getTranslations(locale);

const sent = Astro.url.searchParams.get('sent') === '1';
const error = Astro.url.searchParams.get('error') === '1';
---

<Layout
  title={`${t.menuContact} – fabio.sh`}
  description="Contact Fabio Gschweidl"
>
  <div class="container mx-auto pt-24 md:pt-40 px-4 md:px-12 pb-12">
    <h1 class="text-3xl md:text-5xl font-andesNeueMedium mb-4 animate-fadeIn_2000">
      {t.contactTitle}
    </h1>

    <p class="text-white/60 font-andesNeueLight mb-8">
      <a
        href={getRelativeLocaleUrl(locale, '/mediakit')}
        class="text-emerald-400 hover:text-emerald-300 transition duration-200 underline underline-offset-4"
      >
        Mediakit
      </a>
    </p>

    <ContactForm t={t} sent={sent} error={error} />
  </div>
</Layout>
