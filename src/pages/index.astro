---
import Layout from '../components/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { getTranslations } from '../i18n/index';

const locale = Astro.currentLocale ?? 'de';
const t = getTranslations(locale);

const sent = Astro.url.searchParams.get('sent') === '1';
const error = Astro.url.searchParams.get('error') === '1';

const isJa = locale === 'ja';
---

<Layout title="fabio.sh" description="Fabio Gschweidl – digital media & IT">
  <div class="h-full w-full grid gap-32 md:gap-56">

    <!-- Hero -->
    <section class="container mx-auto pt-24 md:pt-60 px-6 md:pl-12">
      <h1
        class={`${isJa ? 'space-y-4 text-5xl md:space-y-6' : 'text-6xl'} w-fit font-andesNeueMedium md:text-9xl block animate-fadeIn_2000 text-transparent bg-linear-to-tr transition-all duration-300 from-white to-transparent bg-clip-text`}
      >
        <span>{t.name}</span>
        <span class="block">{t.lastname}</span>
        <span class="block animate-fadeIn_2200 text-xl md:text-3xl text-emerald-500 mt-4 font-andesNeueMedium transition duration-300 underline-offset-8 drop-shadow-xs">
          \ digital media &amp; IT
        </span>
      </h1>
    </section>

    <!-- Contact section -->
    <section class="container mx-auto px-4 md:px-12 pb-8" aria-labelledby="contact-heading">
      <h2 id="contact-heading" class="text-3xl md:text-5xl font-andesNeueMedium mb-4">
        {t.contactTitle}
      </h2>

      <ContactForm t={t} sent={sent} error={error} />
    </section>

  </div>
</Layout>
