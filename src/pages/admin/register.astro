---
import '../../styles/globals.css';
import { getDb } from '../../lib/db';
import { validateSession } from '../../lib/admin-auth';

if (validateSession(Astro.cookies))  return Astro.redirect('/admin');

const db = getDb();
const authState = db.prepare(`
  SELECT
    (SELECT COUNT(*) FROM webauthn_credentials) as passkeys,
    (SELECT COUNT(*) FROM admin_password)        as passwords
`).get() as { passkeys: number; passwords: number };
const hasPasskey = authState.passkeys > 0;
const hasPassword = authState.passwords > 0;

if (hasPasskey && hasPassword) return Astro.redirect('/admin/login');

const error = Astro.url.searchParams.get('error');
const pwSet = Astro.url.searchParams.get('pw') === 'set';

const errorMessages: Record<string, string> = {
  missing: 'Email and password are required.',
  mismatch: 'Passwords do not match.',
  short: 'Password must be at least 12 characters.',
  exists: 'Password credentials already set.',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Setup – fabio.sh</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body class="bg-[#0a0a0a] text-gray-200 min-h-screen flex items-center justify-center p-6 font-sans">
    <div class="bg-[#111] border border-[#222] rounded-xl p-8 w-full max-w-md">
      <h1 class="text-xl font-semibold text-gray-50 mb-1">Admin Setup</h1>
      <p class="text-xs text-gray-500 mb-6">First-time credential registration</p>

      {error && (
        <div class="bg-[#1f0a0a] border border-red-900 text-red-300 rounded px-3 py-2 text-xs mb-4">
          {errorMessages[error] ?? 'An error occurred.'}
        </div>
      )}
      {pwSet && (
        <div class="bg-[#0a1f0a] border border-green-900 text-green-300 rounded px-3 py-2 text-xs mb-4">
          Password saved successfully.
        </div>
      )}

      {!hasPassword && (
        <div>
          <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Email + Password</h2>
          <form action="/api/auth/setup-password" method="POST">
            <label for="email" class="block text-xs text-gray-400 mb-1">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email"
              class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm mb-3 outline-none focus:border-emerald-400 transition-colors" />
            <label for="password" class="block text-xs text-gray-400 mb-1">Password (min. 12 chars)</label>
            <input id="password" name="password" type="password" required minlength="12" autocomplete="new-password"
              class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm mb-3 outline-none focus:border-emerald-400 transition-colors" />
            <label for="confirm_password" class="block text-xs text-gray-400 mb-1">Confirm Password</label>
            <input id="confirm_password" name="confirm_password" type="password" required minlength="12" autocomplete="new-password"
              class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm mb-3 outline-none focus:border-emerald-400 transition-colors" />
            <button type="submit" class="w-full bg-emerald-500 text-white py-2.5 rounded-lg border-0 cursor-pointer text-sm font-medium hover:bg-emerald-600 transition-colors mt-1">
              Set Password
            </button>
          </form>
        </div>
      )}

      {hasPassword && (
        <p class="text-emerald-400 text-xs mt-2">✓ Password credentials set.</p>
      )}

      {!hasPasskey && (
        <div class={hasPassword ? 'mt-6 pt-6 border-t border-gray-800' : 'mt-6'}>
          <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Passkey (WebAuthn)</h2>
          <button id="register-passkey-btn" type="button"
            class="w-full bg-gray-800 text-gray-200 py-2.5 rounded-lg border border-gray-700 cursor-pointer text-sm hover:bg-gray-700 transition-colors disabled:opacity-50">
            Register Passkey
          </button>
          <div id="passkey-status" class="text-xs text-gray-500 mt-2 min-h-5"></div>
        </div>
      )}

      {hasPasskey && (
        <p class="text-emerald-400 text-xs mt-4">✓ Passkey registered.</p>
      )}

      {(hasPasskey || hasPassword) && (
        <div class="mt-6 text-center">
          <a href="/admin/login" class="text-emerald-400 text-sm no-underline hover:underline">→ Go to Login</a>
        </div>
      )}
    </div>

    <script>
      const btn = document.getElementById('register-passkey-btn') as HTMLButtonElement | null;
      const status = document.getElementById('passkey-status');
      if (btn) btn.addEventListener('click', async () => {
          btn.disabled = true;
          if (status) status.textContent = 'Requesting options…';
          try {
            const optRes = await fetch('/api/auth/register-start', { method: 'POST' });
            if (!optRes.ok) throw new Error(await optRes.text());
                        const options = await optRes.json();
            
            if (status) status.textContent = 'Waiting for passkey…';
            const { startRegistration } = await import('@simplewebauthn/browser');
            // the fetched value already is the PublicKeyCredentialCreationOptionsJSON
            const attResp = await startRegistration({ optionsJSON: options });
            if (status) status.textContent = 'Verifying…';


            const finRes = await fetch('/api/auth/register-finish', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(attResp),
            });
            if (!finRes.ok) throw new Error(await finRes.text());

            if (status) status.textContent = '✓ Passkey registered! Redirecting…';
            setTimeout(() => { window.location.href = '/admin'; }, 1000);
          } catch (err) {
            if (status) status.textContent = '✗ ' + (err instanceof Error ? err.message : 'Error');
            btn.disabled = false;
          }
        });
    </script>
  </body>
</html>
