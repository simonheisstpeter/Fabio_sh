---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getAllCourses } from '../../../lib/db';

const courses = getAllCourses();
const allPlatforms = [...new Set(courses.map(c => c.platform).filter(Boolean))].sort();
const allTopics = [...new Set(courses.flatMap(c => c.topics))].sort();
---

<AdminLayout title="New Course">
  <h1 class="text-2xl font-semibold text-gray-50 mb-6">New Course</h1>

  <form action="/api/admin/courses" method="POST" enctype="multipart/form-data" class="max-w-2xl">

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label for="id" class="block text-xs text-gray-400 mb-1">ID (slug)</label>
        <input id="id" name="id" type="text" required pattern="[a-z0-9\-]+" title="Lowercase letters, numbers, hyphens"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
      </div>
      <div>
        <label for="title" class="block text-xs text-gray-400 mb-1">Title</label>
        <input id="title" name="title" type="text" required
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label for="platform" class="block text-xs text-gray-400 mb-1">Platform</label>
        <input id="platform" name="platform" type="text" placeholder="Udemy, Coursera…"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
        <div class="mt-2 flex flex-wrap gap-1">
          {allPlatforms.map(p => (
            <button type="button" class="platform-suggest px-2 py-0.5 rounded text-xs bg-neutral-800 text-neutral-400 hover:text-white hover:bg-neutral-700 border border-neutral-700 transition-colors" data-val={p}>
              {p}
            </button>
          ))}
        </div>
      </div>
      <div>
        <label for="status" class="block text-xs text-gray-400 mb-1">Status</label>
        <select id="status" name="status"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors">
          <option value="not_started">Not Started</option>
          <option value="in_progress">In Progress</option>
          <option value="completed">Completed</option>
        </select>
      </div>
    </div>

    <div class="mb-4">
      <label for="topics" class="block text-xs text-gray-400 mb-1">Topics (one per line)</label>
      <textarea id="topics" name="topics" rows="3" placeholder="TypeScript&#10;Web Development"
        class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-xs resize-y outline-none focus:border-emerald-400 transition-colors font-mono"></textarea>
      <div class="mt-2 flex flex-wrap gap-1">
        {allTopics.map(t => (
          <button type="button" class="topic-suggest px-2 py-0.5 rounded text-xs bg-neutral-800 text-neutral-400 hover:text-white hover:bg-neutral-700 border border-neutral-700 transition-colors" data-val={t}>
            {t}
          </button>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label for="progress" class="block text-xs text-gray-400 mb-1">Progress (%)</label>
        <input id="progress" name="progress" type="number" min="0" max="100" value="0"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
      </div>
      <div>
        <label for="url" class="block text-xs text-gray-400 mb-1">URL</label>
        <input id="url" name="url" type="text"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label for="start_date" class="block text-xs text-gray-400 mb-1">Start Date</label>
        <input id="start_date" name="start_date" type="date"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
      </div>
      <div>
        <label for="end_date" class="block text-xs text-gray-400 mb-1">End Date</label>
        <input id="end_date" name="end_date" type="date"
          class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors" />
      </div>
    </div>

    <div class="mb-4">
      <label for="notes" class="block text-xs text-gray-400 mb-1">Notes</label>
      <textarea id="notes" name="notes" rows="3"
        class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm resize-y outline-none focus:border-emerald-400 transition-colors font-sans"></textarea>
    </div>

    <div class="mb-4">
      <label for="certificate" class="block text-xs text-gray-400 mb-1">Certificate (PDF, JPG, PNG — max 10 MB)</label>
      <input id="certificate" name="certificate" type="file" accept=".pdf,.jpg,.jpeg,.png"
        class="w-full bg-[#1a1a1a] border border-gray-700 rounded text-gray-50 px-3 py-2 text-sm outline-none focus:border-emerald-400 transition-colors file:mr-3 file:bg-neutral-700 file:text-gray-200 file:border-0 file:rounded file:px-2 file:py-1 file:text-xs file:cursor-pointer" />
    </div>

    <div class="flex gap-6 mb-6">
      <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-200">
        <input type="checkbox" name="published" value="1" class="accent-emerald-500" />
        Published
      </label>
    </div>

    <div class="flex gap-3">
      <button type="submit" class="bg-emerald-500 text-white px-6 py-2 rounded-lg border-0 cursor-pointer text-sm font-medium hover:bg-emerald-600 transition-colors">
        Create Course
      </button>
      <a href="/admin/courses" class="bg-gray-800 text-gray-200 px-4 py-2 rounded-lg no-underline text-sm border border-gray-700 hover:bg-gray-700 transition-colors">
        Cancel
      </a>
    </div>
  </form>
</AdminLayout>

<script>
  const platformInput = document.getElementById('platform') as HTMLInputElement;
  document.querySelectorAll<HTMLButtonElement>('.platform-suggest').forEach(btn => {
    btn.addEventListener('click', () => { platformInput.value = btn.dataset.val ?? ''; });
  });

  const topicsTA = document.getElementById('topics') as HTMLTextAreaElement;
  document.querySelectorAll<HTMLButtonElement>('.topic-suggest').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = btn.dataset.val ?? '';
      const lines = topicsTA.value.split('\n').map(l => l.trim()).filter(Boolean);
      if (!lines.includes(val)) {
        topicsTA.value = lines.length ? lines.join('\n') + '\n' + val : val;
      }
    });
  });
</script>
