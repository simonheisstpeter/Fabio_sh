---
import Layout from '../layouts/default.astro';
import { getAllCourses } from '../lib/db';
import { getTranslations } from '../i18n/index';

const locale = Astro.currentLocale ?? 'de';
const t = getTranslations(locale);

const allCourses = getAllCourses().filter(c => c.published);
const platforms = [...new Set(allCourses.map(c => c.platform).filter(Boolean))].sort();

// Group by platform; courses with no platform go under ''
const grouped = new Map<string, typeof allCourses>();
for (const c of allCourses) {
  const key = c.platform || '';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(c);
}
// Sort: named platforms first (alphabetical), then ungrouped
const groupKeys = [...platforms, ...(grouped.has('') ? [''] : [])];

const STATUS_LABEL: Record<string, string> = {
  not_started: 'Not Started',
  in_progress: 'In Progress',
  completed: 'Completed',
};
---

<Layout title="Courses" description="Courses I'm taking or have completed." locale={locale}>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-semibold text-gray-50 mb-2">Courses</h1>
    <p class="text-gray-400 mb-8">An overview of courses I have taken, am currently working through, or plan to start.</p>

    {(allCourses.length > 0) && (
      <div class="flex flex-wrap gap-2 mb-8">
        <button type="button" class="filter-btn active px-3 py-1 rounded-full border text-xs transition-colors
          border-emerald-500 text-emerald-400 bg-emerald-950 cursor-pointer" data-filter="all">
          All
        </button>
        <button type="button" class="filter-btn px-3 py-1 rounded-full border text-xs transition-colors
          border-gray-700 text-gray-400 hover:border-emerald-500 hover:text-emerald-400 cursor-pointer" data-filter="not_started">
          Not Started
        </button>
        <button type="button" class="filter-btn px-3 py-1 rounded-full border text-xs transition-colors
          border-gray-700 text-gray-400 hover:border-emerald-500 hover:text-emerald-400 cursor-pointer" data-filter="in_progress">
          In Progress
        </button>
        <button type="button" class="filter-btn px-3 py-1 rounded-full border text-xs transition-colors
          border-gray-700 text-gray-400 hover:border-emerald-500 hover:text-emerald-400 cursor-pointer" data-filter="completed">
          Completed
        </button>
        {platforms.map(p => (
          <button type="button" class="filter-btn px-3 py-1 rounded-full border text-xs transition-colors
            border-gray-700 text-gray-400 hover:border-emerald-500 hover:text-emerald-400 cursor-pointer" data-filter={`platform:${p}`}>
            {p}
          </button>
        ))}
      </div>
    )}

    {allCourses.length === 0 ? (
      <p class="text-gray-500 text-sm">No courses published yet.</p>
    ) : (
      <ul id="courses-container" class="flex flex-col gap-10">
        {groupKeys.map(platform => {
          const courses = grouped.get(platform) ?? [];
          return (
            <li>
              <section class="platform-group" data-platform={platform}>
                <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-4 pb-2 border-b border-[#222]">
                  {platform || 'Other'}
                  <span class="group-count ml-2 text-gray-600 font-normal normal-case tracking-normal">
                    ({courses.length})
                  </span>
                </h2>
                <div class="grid gap-4 sm:grid-cols-2">
                  {courses.map(c => (
                    <article
                      class="course-card bg-[#111] border border-[#222] rounded-xl p-5 flex flex-col gap-3"
                      data-status={c.status}
                      data-platform={c.platform}>

                      <div class="flex items-start justify-between gap-2">
                        <h3 class="text-base font-semibold text-gray-100 leading-tight">{c.title}</h3>
                        <span class={`shrink-0 px-2 py-0.5 rounded text-xs font-medium ${
                          c.status === 'completed' ? 'text-emerald-400 bg-emerald-950' :
                          c.status === 'in_progress' ? 'text-amber-400 bg-amber-950' :
                          'text-gray-400 bg-gray-800'
                        }`}>
                          {STATUS_LABEL[c.status]}
                        </span>
                      </div>

                      <div class="flex items-center gap-2">
                        <div class="flex-1 bg-[#1a1a1a] rounded-full h-1.5">
                          <div class="bg-emerald-500 h-1.5 rounded-full transition-all" style={`width:${c.progress}%`}></div>
                        </div>
                        <span class="text-xs text-gray-500 shrink-0">{c.progress}%</span>
                      </div>

                      {c.topics.length > 0 && (
                        <div class="flex flex-wrap gap-1">
                          {c.topics.map(topic => (
                            <span class="px-2 py-0.5 rounded bg-[#1a1a1a] text-gray-500 text-xs">{topic}</span>
                          ))}
                        </div>
                      )}

                      {(c.startDate || c.endDate) && (
                        <p class="text-xs text-gray-600">
                          {c.startDate && <span>{c.startDate}</span>}
                          {c.startDate && c.endDate && <span> – </span>}
                          {c.endDate && <span>{c.endDate}</span>}
                        </p>
                      )}

                      {c.notes && (
                        <p class="text-xs text-gray-500 leading-relaxed">{c.notes}</p>
                      )}

                      <div class="flex gap-3 mt-auto pt-1">
                        {c.url && (
                          <a href={c.url} target="_blank" rel="noopener noreferrer"
                            class="text-xs text-emerald-400 no-underline hover:underline">
                            View Course →
                          </a>
                        )}
                        {c.hasCertificate && (
                          <a href={`/api/courses/${c.id}/certificate`}
                            class="text-xs text-gray-400 no-underline hover:text-emerald-400 transition-colors">
                            Certificate ↓
                          </a>
                        )}
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.course-card');
  const groups = document.querySelectorAll<HTMLElement>('.platform-group');

  const activeClass = ['border-emerald-500', 'text-emerald-400', 'bg-emerald-950'];
  const inactiveClass = ['border-gray-700', 'text-gray-400', 'hover:border-emerald-500', 'hover:text-emerald-400'];

  function updateGroupCounts() {
    groups.forEach(group => {
      const visible = [...group.querySelectorAll<HTMLElement>('.course-card')]
        .filter(c => c.style.display !== 'none').length;
      const countEl = group.querySelector('.group-count');
      if (countEl) countEl.textContent = `(${visible})`;
      group.style.display = visible === 0 ? 'none' : '';
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      buttons.forEach(b => {
        b.classList.remove(...activeClass);
        b.classList.add(...inactiveClass);
      });
      btn.classList.add(...activeClass);
      btn.classList.remove(...inactiveClass);

      cards.forEach(card => {
        if (filter === 'all') {
          card.style.display = '';
        } else if (filter.startsWith('platform:')) {
          card.style.display = card.dataset.platform === filter.slice(9) ? '' : 'none';
        } else {
          card.style.display = card.dataset.status === filter ? '' : 'none';
        }
      });

      updateGroupCounts();
    });
  });
</script>
