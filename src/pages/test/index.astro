---
import Layout from "../../components/Layout.astro";
import Hero from "../../components/Hero.astro";
import Hero2 from "../../components/Hero2.astro";
import Hero3 from "../../components/Hero3.astro";
import Hero4 from "../../components/Hero4.astro";
import Hero5 from "../../components/Hero5.astro";
import Hero6 from "../../components/Hero6.astro";

import ContactForm from "../../components/ContactForm.astro";
import ProjectTeaser from "../../components/projects/ProjectTeaser.astro";
import { getTranslations } from "../../i18n/index";
import { getAllProjects } from "../../lib/db";

const locale = Astro.currentLocale ?? "de";
const t = getTranslations(locale);

const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error") === "1";

const isJa = locale === "ja";

const previewProjects = getAllProjects()
    .filter((p) => p.published && !p.finished && p.online)
    .slice(0, 4);
---

<Layout title="fabio.sh" description="Fabio Gschweidl – digital media & IT">
    <div class="h-full w-full grid gap-32 md:gap-56">
        <!-- Hero -->
        <Hero t={t} isJa={isJa} />
        <Hero2 t={t} isJa={isJa} />
        <Hero3 t={t} isJa={isJa} />
        <Hero4 t={t} isJa={isJa} />
        <Hero5 t={t} isJa={isJa} />
        <Hero6 t={t} isJa={isJa} />

        <!-- Projects teaser -->
        <ProjectTeaser projects={previewProjects} locale={locale} t={t} />

        <!-- Contact section -->
        <section
            class="container mx-auto px-4 md:px-12 pb-8"
            aria-labelledby="contact-heading"
        >
            <h2
                id="contact-heading"
                class="text-3xl md:text-5xl font-andesNeueMedium mb-4"
            >
                {t.contactTitle}
            </h2>

            <ContactForm t={t} sent={sent} error={error} />
        </section>
    </div>
</Layout>
