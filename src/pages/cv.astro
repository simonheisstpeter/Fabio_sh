---
import Layout from '../components/Layout.astro';
import { getCvSecretByValue, getCvFiles } from '../lib/db';

const secret = Astro.cookies.get('cv_secret')?.value ?? '';
const validSecret = secret ? getCvSecretByValue(secret) : null;
const cvFiles = getCvFiles();

const hasAccess = Boolean(validSecret);
const hasError = Astro.url.searchParams.get('error') === '1';
---

<Layout title="CV – fabio.sh" description="Fabio Gschweidl – CV">
  <div class="container mx-auto py-24 md:py-36 px-4 md:px-12 min-h-[80vh] flex flex-col">
    {hasAccess ? (
      <div class="flex flex-col flex-1 gap-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <h1 class="text-4xl font-andesNeueMedium">CV</h1>
          <div class="flex items-center gap-3 flex-wrap">
            <!-- Language tabs -->
            <div id="lang-tabs" class="flex rounded-lg border border-white/10 overflow-hidden text-sm">
              <button
                data-lang="de"
                class="lang-tab px-4 py-1.5 transition-colors"
                class:list={[cvFiles.de ? '' : 'opacity-40 cursor-not-allowed']}
              >Deutsch</button>
              <button
                data-lang="en"
                class="lang-tab px-4 py-1.5 border-l border-white/10 transition-colors"
                class:list={[cvFiles.en ? '' : 'opacity-40 cursor-not-allowed']}
              >English</button>
            </div>
            <!-- Download button -->
            <a
              id="download-btn"
              href="/api/cv/file?lang=de"
              download
              class="inline-flex items-center gap-2 bg-white text-black px-5 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors no-underline"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download
            </a>
          </div>
        </div>

        {(cvFiles.de || cvFiles.en) ? (
          <iframe
            id="cv-frame"
            src="/api/cv/file?lang=de"
            class="w-full flex-1 rounded-lg border border-white/10"
            style="min-height: 80vh;"
            title="CV"
          />
        ) : (
          <p class="text-white/50">No CV has been uploaded yet.</p>
        )}
      </div>
    ) : (
      <div class="flex flex-col items-center justify-center flex-1 gap-8">
        <div class="w-full max-w-sm">
          <h1 class="text-4xl font-andesNeueMedium mb-2">CV</h1>
          <p class="text-white/50 mb-8 text-sm">Enter the access code to view this CV.</p>

          {hasError && (
            <p class="text-red-400 text-sm mb-4">Invalid access code. Please try again.</p>
          )}

          <form method="POST" action="/api/cv/access" class="flex flex-col gap-4">
            <input
              type="text"
              name="secret"
              placeholder="Access code"
              autocomplete="off"
              autofocus
              required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-white/30 transition-colors text-sm"
            />
            <button
              type="submit"
              class="w-full bg-white text-black py-3 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors cursor-pointer"
            >
              View CV
            </button>
          </form>
        </div>
      </div>
    )}
  </div>
</Layout>

{hasAccess && (
  <script define:vars={{ hasDE: Boolean(cvFiles.de), hasEN: Boolean(cvFiles.en) }}>
    const frame = document.getElementById('cv-frame');
    const downloadBtn = document.getElementById('download-btn');
    const tabs = document.querySelectorAll('.lang-tab');

    // Pick initial lang: prefer de if available, else en
    let activeLang = hasDE ? 'de' : 'en';

    function applyLang(lang) {
      activeLang = lang;
      if (frame) frame.src = `/api/cv/file?lang=${lang}`;
      if (downloadBtn) downloadBtn.href = `/api/cv/file?lang=${lang}`;
      tabs.forEach((tab) => {
        const isActive = tab.dataset.lang === lang;
        tab.classList.toggle('bg-white', isActive);
        tab.classList.toggle('text-black', isActive);
        tab.classList.toggle('text-white/60', !isActive);
      });
    }

    tabs.forEach((tab) => {
      const lang = tab.dataset.lang;
      const available = lang === 'de' ? hasDE : hasEN;
      if (available) {
        tab.addEventListener('click', () => applyLang(lang));
      }
    });

    applyLang(activeLang);
  </script>
)}
